{
	"name": "homekeep",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "pnpm@11.1.2",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"docker:up": "docker compose up",
		"docker:build": "docker compose up --build",
		"docker:down": "docker compose down",
		"db:migrate": "docker compose exec app ./node_modules/.bin/prisma migrate dev",
		"db:studio": "prisma studio",
		"db:reset": "docker compose exec app ./node_modules/.bin/prisma migrate reset",
		"make-admin": "docker compose exec app ./node_modules/.bin/tsx scripts/make-admin.ts",
		"seed": "docker compose exec app ./node_modules/.bin/tsx scripts/seed.ts"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@prisma/engines",
			"prisma"
		]
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.3.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@types/node": "^25.8.0",
		"@types/nodemailer": "^8.0.0",
		"@types/pg": "^8.20.0",
		"dotenv": "^17.4.2",
		"jsdom": "^29.1.1",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.2",
		"prisma": "^7.8.0",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.3.0",
		"tsx": "^4.19.0",
		"typescript": "^6.0.2",
		"vite": "^8.0.7",
		"vitest": "^4.1.6"
	},
	"dependencies": {
		"@lucide/svelte": "^1.16.0",
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"better-auth": "^1.6.11",
		"nodemailer": "^8.0.7",
		"pg": "^8.20.0"
	}
}
